<div id="app" class="fade-in">

  <!-- Page header -->
  <div style="background:var(--color-ivory); border-bottom:1px solid var(--color-mist); padding:2.5rem 0 2rem;">
    <div class="af-container">
      <span class="af-section-label">Member Area</span>
      <h1 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,2.8rem); color:var(--color-text-dark); font-weight:400; margin:0;">我的訂單</h1>
    </div>
  </div>

  <div style="background:var(--color-cream); padding:clamp(2.5rem,5vw,4rem) 0; min-height:50vh;">
    <div class="af-container">
      <div style="display:grid; grid-template-columns:220px 1fr; gap:3rem; align-items:start;">

        <!-- Sidebar -->
        <aside style="position:sticky; top:88px;">
          <div style="background:#fff; border:1px solid var(--color-mist); overflow:hidden;">
            <div style="background:var(--color-forest); padding:1.5rem 1.25rem;">
              <p style="font-family:var(--font-display); font-style:italic; font-size:1.1rem; color:var(--color-text-on-dark); margin-bottom:0.2rem;">會員中心</p>
              <p style="font-size:0.65rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(200,217,205,0.65);">Member Center</p>
            </div>
            <nav style="padding:0.5rem 0;">
              <a href="#" style="
                display:flex; align-items:center; padding:0.75rem 1.25rem;
                font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:500;
                color:var(--color-text-light); text-decoration:none;
                transition:background 0.2s, color 0.2s;
              "
                onmouseover="this.style.background='var(--color-ivory)'; this.style.color='var(--color-forest)'"
                onmouseout="this.style.background=''; this.style.color='var(--color-text-light)'"
              >個人資料</a>
              <a href="/orders" style="
                display:flex; align-items:center; padding:0.75rem 1.25rem;
                font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:500;
                color:var(--color-forest); text-decoration:none;
                background:var(--color-forest-pale);
                border-left:2px solid var(--color-forest);
              ">訂單管理</a>
              <a href="#" style="
                display:flex; align-items:center; padding:0.75rem 1.25rem;
                font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:500;
                color:var(--color-text-light); text-decoration:none;
                transition:background 0.2s, color 0.2s;
              "
                onmouseover="this.style.background='var(--color-ivory)'; this.style.color='var(--color-forest)'"
                onmouseout="this.style.background=''; this.style.color='var(--color-text-light)'"
              >收件地址</a>
              <a href="#" style="
                display:flex; align-items:center; padding:0.75rem 1.25rem;
                font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:500;
                color:var(--color-text-light); text-decoration:none;
                transition:background 0.2s, color 0.2s;
              "
                onmouseover="this.style.background='var(--color-ivory)'; this.style.color='var(--color-forest)'"
                onmouseout="this.style.background=''; this.style.color='var(--color-text-light)'"
              >帳號安全</a>
            </nav>
            <!-- Points -->
            <div style="border-top:1px solid var(--color-mist); padding:1.25rem; background:var(--color-ivory);">
              <p style="font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-forest-mid); margin-bottom:0.3rem; font-weight:500;">花藝積點</p>
              <p style="font-family:var(--font-display); font-size:1.6rem; color:var(--color-forest); line-height:1;">1,240
                <span style="font-size:0.65rem; font-family:var(--font-body); letter-spacing:0.14em; text-transform:uppercase; color:var(--color-text-light); margin-left:2px;">pts</span>
              </p>
            </div>
          </div>
        </aside>

        <!-- Orders list -->
        <div>
          <!-- Loading -->
          <div v-if="loading" style="display:flex; justify-content:center; padding:4rem 0;">
            <div class="af-spinner"></div>
          </div>

          <!-- Empty -->
          <div v-else-if="orders.length === 0" style="
            text-align:center; padding:4rem 2rem;
            border:1.5px dashed var(--color-mist); background:var(--color-ivory);
          ">
            <div style="font-size:2.5rem; margin-bottom:1rem; opacity:0.2;">📦</div>
            <p style="font-size:0.9rem; color:var(--color-text-light); margin-bottom:0.4rem;">您目前尚無任何訂單</p>
            <p style="font-size:0.78rem; color:var(--color-text-light); opacity:0.6; margin-bottom:1.75rem;">快去選購喜歡的花束吧！</p>
            <a href="/" class="btn-primary">去逛逛</a>
          </div>

          <!-- Orders -->
          <div v-else style="display:flex; flex-direction:column; gap:1px; background:var(--color-mist); border:1px solid var(--color-mist); overflow:hidden;">
            <a
              v-for="order in orders"
              :key="order.id"
              :href="'/orders/' + order.id"
              style="
                display:grid;
                grid-template-columns:1fr auto auto;
                align-items:center;
                gap:1.5rem;
                padding:1.5rem;
                background:#fff;
                text-decoration:none;
                transition:background 0.2s;
              "
              onmouseover="this.style.background='var(--color-ivory)'"
              onmouseout="this.style.background='#fff'"
            >
              <div>
                <p style="font-size:0.72rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-text-mid); font-weight:500; margin-bottom:0.3rem;">
                  訂單 {{ order.order_no }}
                </p>
                <p style="font-size:0.75rem; color:var(--color-text-light);">
                  {{ new Date(order.created_at).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) }}
                </p>
              </div>
              <div style="text-align:right;">
                <p style="font-family:var(--font-display); font-size:1.2rem; color:var(--color-text-dark); line-height:1;">NT$&thinsp;{{ order.total_amount.toLocaleString() }}</p>
              </div>
              <div style="display:flex; align-items:center; gap:0.75rem;">
                <span
                  style="
                    font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; font-weight:500;
                    padding:0.3rem 0.85rem; border:1px solid currentColor;
                  "
                  :class="statusMap[order.status]?.cls || 'status-pending'"
                >
                  {{ statusMap[order.status]?.label || order.status }}
                </span>
                <span style="color:var(--color-forest-mid); font-size:0.9rem;">→</span>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
