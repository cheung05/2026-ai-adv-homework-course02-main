<div id="app" class="fade-in">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-light text-text-primary">商品管理</h1>
    <button
      @click="openCreate"
      class="premium-btn bg-rose-primary text-white px-6 py-2.5 rounded-none text-xs font-semibold tracking-wider hover:bg-rose-dark shadow-sm hover:shadow"
    >
      + 新增商品
    </button>
  </div>

  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border-3 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else>
    <div class="bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 shadow-[0_4px_25px_rgba(156,74,90,0.01)] overflow-hidden">
      <table class="w-full text-xs">
        <thead>
          <tr class="bg-rose-bg/20 text-text-secondary border-b border-rose-bg/30">
            <th class="text-left px-6 py-4 font-semibold">圖片</th>
            <th class="text-left px-6 py-4 font-semibold">商品名稱</th>
            <th class="text-right px-6 py-4 font-semibold">價格</th>
            <th class="text-right px-6 py-4 font-semibold">庫存</th>
            <th class="text-right px-6 py-4 font-semibold">操作</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="product in products" :key="product.id" class="border-b border-rose-bg/10 hover:bg-white/30 transition-colors">
            <td class="px-6 py-4">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=100'"
                :alt="product.name"
                class="w-12 h-12 rounded-none object-cover border border-rose-bg/20"
              />
            </td>
            <td class="px-6 py-4 text-text-primary font-medium">{{ product.name }}</td>
            <td class="px-6 py-4 text-right text-text-secondary font-medium">NT$ {{ product.price.toLocaleString() }}</td>
            <td class="px-6 py-4 text-right text-text-secondary">{{ product.stock }}</td>
            <td class="px-6 py-4 text-right space-x-2">
              <button
                @click="openEdit(product)"
                class="premium-btn text-rose-primary hover:text-white hover:bg-rose-primary text-[10px] font-semibold border border-rose-primary rounded-none px-4 py-1.5 transition-all"
              >
                編輯
              </button>
              <button
                @click="confirmDeleteFn(product.id)"
                class="premium-btn text-red-500 hover:text-white hover:bg-red-500 text-[10px] font-semibold border border-red-300 rounded-none px-4 py-1.5 transition-all"
              >
                刪除
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div v-if="pagination.totalPages > 1" class="flex justify-center gap-3 mt-8">
      <button
        v-for="p in pagination.totalPages"
        :key="p"
        @click="loadProducts(p)"
        class="w-10 h-10 rounded-none text-xs font-semibold transition-all border border-rose-bg/25 shadow-sm"
        :class="p === pagination.page ? 'bg-rose-primary text-white border-rose-primary' : 'bg-white text-text-secondary hover:bg-rose-bg'"
      >
        {{ p }}
      </button>
    </div>
  </template>

  <!-- Product Modal -->
  <div v-if="modalVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/20 backdrop-blur-sm" @click="modalVisible = false"></div>
    <div class="relative bg-white rounded-none border border-rose-bg/30 shadow-2xl w-full max-w-lg mx-4 p-8 animate-scale-up">
      <h3 class="text-lg font-semibold text-text-primary mb-6 pb-2 border-b border-rose-bg/30">
        {{ editingProduct ? '編輯商品' : '新增商品' }}
      </h3>
      <form @submit.prevent="handleSave" class="space-y-5">
        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">商品名稱 *</label>
          <input v-model="form.name" type="text" placeholder="請輸入商品名稱" class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary transition-all bg-white" required />
        </div>
        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">商品描述</label>
          <textarea v-model="form.description" rows="3" placeholder="請輸入商品描述..." class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary transition-all bg-white"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">價格 *</label>
            <input v-model.number="form.price" type="number" min="1" placeholder="NT$" class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary transition-all bg-white" required />
          </div>
          <div>
            <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">庫存 *</label>
            <input v-model.number="form.stock" type="number" min="0" placeholder="0" class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary transition-all bg-white" required />
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">圖片 URL</label>
          <input v-model="form.image_url" type="text" placeholder="請輸入圖片 URL" class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary transition-all bg-white" />
        </div>
        <div class="flex justify-end gap-3 pt-4 border-t border-rose-bg/20">
          <button type="button" @click="modalVisible = false" class="px-5 py-2.5 text-xs font-semibold tracking-wider rounded-none border border-rose-bg text-text-secondary hover:bg-rose-bg/20 transition-all">取消</button>
          <button type="submit" :disabled="saving" class="premium-btn px-6 py-2.5 text-xs font-semibold tracking-wider rounded-none bg-rose-primary text-white hover:bg-rose-dark disabled:opacity-40 shadow-sm transition-all">
            {{ saving ? '儲存中...' : '儲存' }}
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Confirm Delete Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/20 backdrop-blur-sm" @click="confirmVisible = false"></div>
    <div class="relative bg-white rounded-none border border-rose-bg/30 shadow-2xl w-full max-w-sm mx-4 p-8 text-center animate-scale-up">
      <h3 class="text-lg font-semibold text-text-primary mb-2">確認刪除</h3>
      <p class="text-text-secondary text-xs mb-6">確定要刪除這個商品嗎？此操作將無法復原。</p>
      <div class="flex gap-4 justify-center">
        <button @click="confirmVisible = false" class="px-5 py-2.5 text-xs font-semibold tracking-wider rounded-none border border-rose-bg text-text-secondary hover:bg-rose-bg/20 transition-all">取消</button>
        <button @click="handleDelete" class="px-5 py-2.5 text-xs font-semibold tracking-wider rounded-none bg-red-500 text-white hover:bg-red-600 shadow-sm transition-all">確認刪除</button>
      </div>
    </div>
  </div>
</div>
