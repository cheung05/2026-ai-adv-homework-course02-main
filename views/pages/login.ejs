<div id="app" class="fade-in">
  <div class="min-h-[60vh] flex items-center justify-center py-12">
    <div class="bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 w-full max-w-md p-10 shadow-[0_10px_35px_rgba(156,74,90,0.02)]">
      <h1 class="text-3xl font-light text-rose-primary text-center mb-8 font-serif italic tracking-wide">
        Aura Flora
      </h1>

      <!-- Tabs -->
      <div class="flex mb-8 border border-rose-bg/50 rounded-none overflow-hidden bg-white/50 p-1">
        <button
          @click="activeTab = 'login'; errors = {}"
          class="flex-1 py-2 text-xs font-semibold tracking-wider transition-all rounded-none"
          :class="activeTab === 'login' ? 'bg-rose-primary text-white shadow-sm' : 'text-text-secondary hover:text-rose-primary'"
        >
          登入
        </button>
        <button
          @click="activeTab = 'register'; errors = {}"
          class="flex-1 py-2 text-xs font-semibold tracking-wider transition-all rounded-none"
          :class="activeTab === 'register' ? 'bg-rose-primary text-white shadow-sm' : 'text-text-secondary hover:text-rose-primary'"
        >
          註冊
        </button>
      </div>

      <!-- Login Form -->
      <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="space-y-6">
        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">Email 信箱</label>
          <input
            v-model="loginForm.email"
            type="email"
            placeholder="請輸入 Email"
            class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
            :class="{ 'border-red-400': errors.email }"
          />
          <p v-if="errors.email" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.email }}</p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">密碼</label>
          <input
            v-model="loginForm.password"
            type="password"
            placeholder="請輸入密碼"
            class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
            :class="{ 'border-red-400': errors.password }"
          />
          <p v-if="errors.password" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.password }}</p>
        </div>

        <button
          type="submit"
          :disabled="submitting"
          class="premium-btn w-full bg-rose-primary text-white py-3.5 rounded-none text-xs font-semibold tracking-widest uppercase hover:bg-rose-dark transition-colors disabled:opacity-40 shadow-sm"
        >
          {{ submitting ? '登入中...' : '登入' }}
        </button>
      </form>

      <!-- Register Form -->
      <form v-else @submit.prevent="handleRegister" class="space-y-6">
        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">姓名</label>
          <input
            v-model="registerForm.name"
            type="text"
            placeholder="請輸入姓名"
            class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
            :class="{ 'border-red-400': errors.name }"
          />
          <p v-if="errors.name" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.name }}</p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">Email 信箱</label>
          <input
            v-model="registerForm.email"
            type="email"
            placeholder="請輸入 Email"
            class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
            :class="{ 'border-red-400': errors.email }"
          />
          <p v-if="errors.email" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.email }}</p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-text-secondary tracking-wider uppercase mb-2">密碼</label>
          <input
            v-model="registerForm.password"
            type="password"
            placeholder="至少 6 個字元"
            class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
            :class="{ 'border-red-400': errors.password }"
          />
          <p v-if="errors.password" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.password }}</p>
        </div>

        <button
          type="submit"
          :disabled="submitting"
          class="premium-btn w-full bg-rose-primary text-white py-3.5 rounded-none text-xs font-semibold tracking-widest uppercase hover:bg-rose-dark transition-colors disabled:opacity-40 shadow-sm"
        >
          {{ submitting ? '註冊中...' : '註冊' }}
        </button>
      </form>
    </div>
  </div>
</div>
