<div id="app" class="fade-in">
  <div style="min-height:70vh; display:flex; align-items:center; justify-content:center; padding:4rem 1rem; background:var(--color-cream);">

    <div style="width:100%; max-width:440px;">
      <!-- Branding -->
      <div style="text-align:center; margin-bottom:2.5rem;">
        <a href="/" style="font-family:var(--font-display); font-style:italic; font-size:2rem; color:var(--color-forest); text-decoration:none; display:block; margin-bottom:0.5rem; transition:opacity 0.2s;"
          onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
          Aura Flora
        </a>
        <p style="font-size:0.65rem; letter-spacing:0.24em; text-transform:uppercase; color:var(--color-text-light);">會員登入 / 註冊</p>
      </div>

      <div style="background:#fff; border:1px solid var(--color-mist); padding:2.5rem;">
        <!-- Tab switcher -->
        <div style="display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid var(--color-mist); margin-bottom:2rem;">
          <button
            @click="activeTab = 'login'; errors = {}"
            style="
              padding:0.75rem 0; font-family:var(--font-body); font-size:0.7rem;
              font-weight:500; letter-spacing:0.14em; text-transform:uppercase;
              background:none; border:none; cursor:pointer; transition:all 0.25s;
              border-bottom:2px solid transparent; margin-bottom:-1px;
            "
            :style="activeTab === 'login'
              ? 'color:var(--color-forest); border-bottom-color:var(--color-forest);'
              : 'color:var(--color-text-light); border-bottom-color:transparent;'"
          >登入</button>
          <button
            @click="activeTab = 'register'; errors = {}"
            style="
              padding:0.75rem 0; font-family:var(--font-body); font-size:0.7rem;
              font-weight:500; letter-spacing:0.14em; text-transform:uppercase;
              background:none; border:none; cursor:pointer; transition:all 0.25s;
              border-bottom:2px solid transparent; margin-bottom:-1px;
            "
            :style="activeTab === 'register'
              ? 'color:var(--color-forest); border-bottom-color:var(--color-forest);'
              : 'color:var(--color-text-light); border-bottom-color:transparent;'"
          >註冊</button>
        </div>

        <!-- Login form -->
        <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" style="display:flex; flex-direction:column; gap:1.25rem;">
          <div>
            <label class="af-label">Email 信箱</label>
            <input v-model="loginForm.email" type="email" placeholder="your@email.com" class="af-input" :class="{ error: errors.email }">
            <p v-if="errors.email" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.email }}</p>
          </div>
          <div>
            <label class="af-label">密碼</label>
            <input v-model="loginForm.password" type="password" placeholder="請輸入密碼" class="af-input" :class="{ error: errors.password }">
            <p v-if="errors.password" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.password }}</p>
          </div>
          <button type="submit" :disabled="submitting" class="btn-primary" style="width:100%; text-align:center; padding:0.9rem; margin-top:0.5rem;">
            {{ submitting ? '登入中…' : '登入' }}
          </button>
        </form>

        <!-- Register form -->
        <form v-else @submit.prevent="handleRegister" style="display:flex; flex-direction:column; gap:1.25rem;">
          <div>
            <label class="af-label">姓名</label>
            <input v-model="registerForm.name" type="text" placeholder="請輸入姓名" class="af-input" :class="{ error: errors.name }">
            <p v-if="errors.name" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.name }}</p>
          </div>
          <div>
            <label class="af-label">Email 信箱</label>
            <input v-model="registerForm.email" type="email" placeholder="your@email.com" class="af-input" :class="{ error: errors.email }">
            <p v-if="errors.email" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.email }}</p>
          </div>
          <div>
            <label class="af-label">密碼</label>
            <input v-model="registerForm.password" type="password" placeholder="至少 6 個字元" class="af-input" :class="{ error: errors.password }">
            <p v-if="errors.password" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.password }}</p>
          </div>
          <button type="submit" :disabled="submitting" class="btn-primary" style="width:100%; text-align:center; padding:0.9rem; margin-top:0.5rem;">
            {{ submitting ? '註冊中…' : '建立帳號' }}
          </button>
        </form>
      </div>

      <!-- Footer note -->
      <p style="text-align:center; font-size:0.75rem; color:var(--color-text-light); margin-top:1.5rem; line-height:1.6;">
        加入 Aura Flora，享受專屬會員花藝優惠
      </p>
    </div>

  </div>
</div>
