<div id="app" class="fade-in">

  <!-- Page header -->
  <div style="background:var(--color-ivory); border-bottom:1px solid var(--color-mist); padding:2.5rem 0 2rem;">
    <div class="af-container">
      <span class="af-section-label">Almost There</span>
      <h1 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,2.8rem); color:var(--color-text-dark); font-weight:400; margin:0;">結帳</h1>
    </div>
  </div>

  <div style="background:var(--color-cream); padding:clamp(2.5rem,5vw,4rem) 0; min-height:50vh;">
    <div class="af-container">

      <!-- Loading -->
      <div v-if="loading" style="display:flex; justify-content:center; padding:5rem 0;">
        <div class="af-spinner"></div>
      </div>

      <div v-else style="display:grid; grid-template-columns:1fr 380px; gap:2.5rem; align-items:start;">

        <!-- Left: Form -->
        <div style="background:#fff; border:1px solid var(--color-mist); padding:2.5rem;">
          <h2 style="font-family:var(--font-display); font-size:1.4rem; color:var(--color-text-dark); font-weight:400; margin-bottom:1.75rem; padding-bottom:1.25rem; border-bottom:1px solid var(--color-mist);">收件資訊</h2>

          <div style="display:flex; flex-direction:column; gap:1.5rem;">
            <div>
              <label class="af-label">收件人姓名</label>
              <input
                v-model="form.recipientName"
                type="text"
                placeholder="請輸入收件人姓名"
                class="af-input"
                :class="{ error: errors.recipientName }"
              >
              <p v-if="errors.recipientName" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.recipientName }}</p>
            </div>

            <div>
              <label class="af-label">Email 信箱</label>
              <input
                v-model="form.recipientEmail"
                type="email"
                placeholder="請輸入 Email"
                class="af-input"
                :class="{ error: errors.recipientEmail }"
              >
              <p v-if="errors.recipientEmail" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.recipientEmail }}</p>
            </div>

            <div>
              <label class="af-label">收件地址</label>
              <input
                v-model="form.recipientAddress"
                type="text"
                placeholder="請輸入收件地址"
                class="af-input"
                :class="{ error: errors.recipientAddress }"
              >
              <p v-if="errors.recipientAddress" style="font-size:0.75rem; color:#C0392B; margin-top:0.35rem;">{{ errors.recipientAddress }}</p>
            </div>
          </div>

          <!-- Delivery info -->
          <div style="
            margin-top:2rem; padding:1.25rem 1.5rem;
            background:var(--color-forest-pale); border:1px solid var(--color-forest-mist);
          ">
            <p style="font-size:0.7rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--color-forest); font-weight:500; margin-bottom:0.5rem;">配送說明</p>
            <p style="font-size:0.8rem; color:var(--color-text-mid); line-height:1.75;">大台北地區可享當日預約配送。下單後我們將以 Email 確認配送時間。</p>
          </div>
        </div>

        <!-- Right: Summary (sticky) -->
        <div style="position:sticky; top:88px;">
          <div style="background:#fff; border:1px solid var(--color-mist); padding:2rem;">
            <h2 style="font-family:var(--font-display); font-size:1.4rem; color:var(--color-text-dark); font-weight:400; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:1px solid var(--color-mist);">訂單摘要</h2>

            <!-- Items list -->
            <div style="display:flex; flex-direction:column; gap:0.6rem; margin-bottom:1.5rem; max-height:200px; overflow-y:auto; padding-right:0.25rem;">
              <div v-for="item in cartItems" :key="item.id" style="display:flex; justify-content:space-between; font-size:0.82rem; gap:1rem;">
                <span style="color:var(--color-text-mid); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1;">
                  {{ item.product.name }}
                  <span style="color:var(--color-text-light);">× {{ item.quantity }}</span>
                </span>
                <span style="color:var(--color-text-dark); font-weight:500; white-space:nowrap;">NT$&thinsp;{{ (item.product.price * item.quantity).toLocaleString() }}</span>
              </div>
            </div>

            <!-- Totals -->
            <div style="border-top:1px solid var(--color-mist); padding-top:1.25rem; display:flex; flex-direction:column; gap:0.6rem; margin-bottom:1.25rem;">
              <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:var(--color-text-light);">
                <span>商品小計</span>
                <span>NT$&thinsp;{{ cartTotal.toLocaleString() }}</span>
              </div>
              <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:var(--color-text-light);">
                <span>運費</span>
                <span :style="cartTotal >= 500 ? 'color:var(--color-forest)' : ''">{{ cartTotal >= 500 ? '免運' : 'NT$&thinsp;150' }}</span>
              </div>
            </div>
            <div style="
              border-top:1px solid var(--color-mist); padding-top:1.25rem;
              display:flex; justify-content:space-between; align-items:baseline;
              margin-bottom:2rem;
            ">
              <span style="font-size:0.85rem; color:var(--color-text-dark); font-weight:500;">總計</span>
              <span style="font-family:var(--font-display); font-size:1.6rem; color:var(--color-coral); line-height:1;">
                NT$&thinsp;{{ (cartTotal + (cartTotal >= 500 ? 0 : 150)).toLocaleString() }}
              </span>
            </div>

            <button
              @click="submitOrder"
              :disabled="submitting"
              class="btn-primary"
              style="width:100%; text-align:center; padding:1rem;"
            >
              {{ submitting ? '處理中…' : '確認送出訂單' }}
            </button>
            <p style="font-size:0.7rem; text-align:center; color:var(--color-text-light); margin-top:0.75rem;">安全加密結帳 · 保障您的隱私</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
