<div id="app" class="fade-in py-6">
  <h1 class="text-3xl font-light text-text-primary mb-8 font-serif">結帳</h1>

  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border-3 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else class="flex flex-col lg:flex-row gap-8">
    <!-- Left: Form -->
    <div class="lg:w-3/5 w-full">
      <div class="bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 p-8 shadow-[0_4px_25px_rgba(156,74,90,0.01)]">
        <h2 class="text-lg font-medium text-text-primary mb-6 pb-3 border-b border-rose-bg/30 font-serif">收件資訊</h2>
        <div class="space-y-6">
          <div>
            <label class="block text-xs font-semibold text-text-secondary tracking-widest uppercase mb-2">收件人姓名</label>
            <input
              v-model="form.recipientName"
              type="text"
              placeholder="請輸入收件人姓名"
              class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
              :class="{ 'border-red-400': errors.recipientName }"
            />
            <p v-if="errors.recipientName" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.recipientName }}</p>
          </div>
          <div>
            <label class="block text-xs font-semibold text-text-secondary tracking-widest uppercase mb-2">Email 信箱</label>
            <input
              v-model="form.recipientEmail"
              type="email"
              placeholder="請輸入 Email"
              class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
              :class="{ 'border-red-400': errors.recipientEmail }"
            />
            <p v-if="errors.recipientEmail" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.recipientEmail }}</p>
          </div>
          <div>
            <label class="block text-xs font-semibold text-text-secondary tracking-widest uppercase mb-2">收件地址</label>
            <input
              v-model="form.recipientAddress"
              type="text"
              placeholder="請輸入收件地址"
              class="w-full border border-rose-bg/60 rounded-none px-5 py-3 text-xs focus:outline-none focus:border-rose-primary focus:bg-white transition-all bg-white/50"
              :class="{ 'border-red-400': errors.recipientAddress }"
            />
            <p v-if="errors.recipientAddress" class="text-red-500 text-[10px] mt-1.5 pl-2">{{ errors.recipientAddress }}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Summary -->
    <div class="lg:w-2/5 w-full">
      <div class="bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 p-8 shadow-[0_4px_25px_rgba(156,74,90,0.01)] sticky top-28">
        <h2 class="text-lg font-medium text-text-primary mb-4 pb-3 border-b border-rose-bg/30 font-serif">訂單摘要</h2>
        <div class="space-y-3 mb-6 max-h-48 overflow-y-auto pr-2">
          <div v-for="item in cartItems" :key="item.id" class="flex justify-between text-xs">
            <span class="text-text-secondary truncate max-w-[70%]">{{ item.product.name }} <span class="text-text-muted">x {{ item.quantity }}</span></span>
            <span class="text-text-primary font-medium">NT$ {{ (item.product.price * item.quantity).toLocaleString() }}</span>
          </div>
        </div>
        <div class="border-t border-rose-bg/30 pt-4 space-y-2.5 text-xs">
          <div class="flex justify-between text-text-secondary">
            <span>商品小計</span>
            <span>NT$ {{ cartTotal.toLocaleString() }}</span>
          </div>
          <div class="flex justify-between text-text-secondary">
            <span>運費</span>
            <span>{{ cartTotal >= 500 ? '免運' : 'NT$ 150' }}</span>
          </div>
        </div>
        <div class="border-t border-rose-bg/30 pt-4 mt-4 flex justify-between items-center">
          <span class="font-medium text-text-primary text-sm">總計</span>
          <span class="font-bold text-lg text-rose-primary font-serif">
            NT$ {{ (cartTotal + (cartTotal >= 500 ? 0 : 150)).toLocaleString() }}
          </span>
        </div>
        <button
          @click="submitOrder"
          :disabled="submitting"
          class="premium-btn w-full mt-6 bg-rose-primary text-white py-3.5 rounded-none text-xs font-semibold tracking-widest uppercase hover:bg-rose-dark transition-colors disabled:opacity-40 shadow-sm"
        >
          {{ submitting ? '處理中...' : '確認送出訂單' }}
        </button>
      </div>
    </div>
  </div>
</div>
