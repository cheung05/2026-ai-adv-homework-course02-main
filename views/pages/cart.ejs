<div id="app" class="fade-in py-6">
  <h1 class="text-3xl font-light text-text-primary mb-8 font-serif">購物車</h1>

  <div v-if="loading" class="flex justify-center py-24">
    <div class="w-8 h-8 border-3 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="items.length === 0" class="text-center py-20 bg-white/40 rounded-none border border-dashed border-rose-bg/30">
    <div class="text-5xl mb-4">🛒</div>
    <p class="text-text-secondary text-sm mb-2">您的購物車目前是空的</p>
    <p class="text-text-muted text-xs mb-6">快去挑選一些美麗的花束來裝點生活吧！</p>
    <a href="/" class="premium-btn inline-block bg-rose-primary text-white px-8 py-3 rounded-none text-xs font-semibold tracking-widest uppercase hover:bg-rose-dark transition-all">去逛逛</a>
  </div>

  <template v-else>
    <!-- Free shipping banner -->
    <div v-if="total < 500" class="bg-blush/80 border border-rose-bg/40 rounded-none p-4 mb-8 text-xs font-medium text-rose-primary text-center tracking-wider">
      ✿ 再消費 <strong>NT$ {{ (500 - total).toLocaleString() }}</strong> 即可享有免運費優惠！
    </div>
    <div v-else class="bg-sage/10 border border-sage/20 rounded-none p-4 mb-8 text-xs font-medium text-sage text-center tracking-wider">
      ✓ 已達免運門檻！我們將為您免費配送。
    </div>

    <!-- Cart Layout Grid -->
    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <!-- Cart Items -->
      <div class="flex-1 w-full bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 p-6 space-y-6">
        <div
          v-for="item in items"
          :key="item.id"
          class="flex flex-col sm:flex-row sm:items-center gap-6 pb-6 border-b border-rose-bg/30 last:border-0 last:pb-0"
        >
          <img
            :src="item.product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=100'"
            :alt="item.product.name"
            class="w-20 h-20 rounded-none object-cover flex-shrink-0 border border-rose-bg/20"
          />
          <div class="flex-1 min-w-0">
            <h3 class="font-medium text-text-primary text-sm truncate">{{ item.product.name }}</h3>
            <p class="text-rose-primary text-xs mt-1">單價 NT$ {{ item.product.price.toLocaleString() }}</p>
          </div>

          <!-- Quantity Controls -->
          <div class="flex items-center gap-4">
            <span class="text-xs text-text-muted sm:hidden">數量</span>
            <div class="flex items-center border border-rose-bg/60 rounded-none overflow-hidden bg-white/60">
              <button
                @click="updateQuantity(item.id, item.quantity - 1)"
                :disabled="item.quantity <= 1"
                class="w-8 h-8 flex items-center justify-center hover:bg-rose-bg/20 text-text-secondary text-sm disabled:opacity-40"
              >
                -
              </button>
              <span class="w-8 h-8 flex items-center justify-center text-xs font-semibold border-x border-rose-bg/30 text-text-primary">
                {{ item.quantity }}
              </span>
              <button
                @click="updateQuantity(item.id, item.quantity + 1)"
                :disabled="item.quantity >= item.product.stock"
                class="w-8 h-8 flex items-center justify-center hover:bg-rose-bg/20 text-text-secondary text-sm disabled:opacity-40"
              >
                +
              </button>
            </div>
          </div>

          <div class="flex items-center justify-between sm:justify-end gap-6 w-full sm:w-auto">
            <p class="text-text-primary font-semibold text-sm w-24 text-right">
              NT$ {{ (item.product.price * item.quantity).toLocaleString() }}
            </p>
            <button
              @click="confirmDelete(item.id)"
              class="text-text-muted hover:text-red-500 transition-colors text-sm"
              title="移除商品"
            >
              ✕
            </button>
          </div>
        </div>
      </div>

      <!-- Summary Card -->
      <div class="w-full lg:w-80 bg-white/40 backdrop-blur-sm rounded-none border border-rose-bg/30 p-6 shadow-[0_4px_25px_rgba(156,74,90,0.01)]">
        <h2 class="text-lg font-medium text-text-primary mb-4 pb-3 border-b border-rose-bg/30 font-serif">訂單摘要</h2>
        <div class="flex justify-between items-center mb-3 text-xs text-text-secondary">
          <span>商品小計</span>
          <span>NT$ {{ total.toLocaleString() }}</span>
        </div>
        <div class="flex justify-between items-center mb-4 text-xs text-text-secondary">
          <span>運費</span>
          <span>{{ total >= 500 ? '免運' : 'NT$ 150' }}</span>
        </div>
        <div class="border-t border-rose-bg/30 pt-4 flex justify-between items-center">
          <span class="font-medium text-text-primary text-sm">總計</span>
          <span class="font-bold text-lg text-rose-primary font-serif">
            NT$ {{ (total + (total >= 500 ? 0 : 150)).toLocaleString() }}
          </span>
        </div>
        <button
          @click="goCheckout"
          class="premium-btn w-full mt-6 bg-rose-primary text-white py-3 rounded-none text-xs font-semibold tracking-widest uppercase hover:bg-rose-dark shadow-sm transition-colors"
        >
          前往結帳
        </button>
      </div>
    </div>
  </template>

  <!-- Confirm Dialog -->
  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/20 backdrop-blur-sm animate-fade-in" @click="confirmVisible = false"></div>
    <div class="relative bg-white rounded-none border border-rose-bg/30 shadow-2xl w-full max-w-sm mx-4 p-8 text-center animate-scale-up">
      <h3 class="text-lg font-medium text-text-primary mb-2 font-serif">確認移除</h3>
      <p class="text-text-secondary text-xs mb-6">您確定要從購物車中移除這個精心挑選的花束嗎？</p>
      <div class="flex gap-4 justify-center">
        <button @click="confirmVisible = false" class="px-5 py-2.5 text-xs font-semibold tracking-widest uppercase rounded-none border border-rose-bg text-text-secondary hover:bg-rose-bg/20 transition-all">取消</button>
        <button @click="handleDelete" class="px-5 py-2.5 text-xs font-semibold tracking-widest uppercase rounded-none bg-red-500 text-white hover:bg-red-600 shadow-sm transition-all">確認移除</button>
      </div>
    </div>
  </div>
</div>
