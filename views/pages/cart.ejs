<div id="app" class="fade-in">

  <!-- Page header band -->
  <div style="background:var(--color-ivory); border-bottom:1px solid var(--color-mist); padding:2.5rem 0 2rem;">
    <div class="af-container">
      <span class="af-section-label">Your Selection</span>
      <h1 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,2.8rem); color:var(--color-text-dark); font-weight:400; margin:0;">購物車</h1>
    </div>
  </div>

  <div style="background:var(--color-cream); padding:clamp(2.5rem,5vw,4rem) 0; min-height:50vh;">
    <div class="af-container">

      <!-- Loading -->
      <div v-if="loading" style="display:flex; justify-content:center; padding:5rem 0;">
        <div class="af-spinner"></div>
      </div>

      <!-- Empty cart -->
      <div v-else-if="items.length === 0" style="
        text-align:center; padding:5rem 2rem;
        border:1.5px dashed var(--color-mist);
        background:var(--color-ivory);
        max-width:480px; margin:0 auto;
      ">
        <div style="font-size:3rem; margin-bottom:1.25rem; opacity:0.2; line-height:1;">🛒</div>
        <h2 style="font-family:var(--font-display); font-size:1.5rem; color:var(--color-text-dark); font-weight:400; margin-bottom:0.5rem;">購物車是空的</h2>
        <p style="font-size:0.85rem; color:var(--color-text-light); margin-bottom:2rem; line-height:1.7;">快去挑選一些美麗的花束來裝點生活吧！</p>
        <a href="/" class="btn-primary">探索花藝</a>
      </div>

      <template v-else>
        <!-- Free shipping notice -->
        <div v-if="total < 500" style="
          background:var(--color-coral-pale);
          border:1px solid var(--color-coral-light);
          padding:0.9rem 1.5rem;
          margin-bottom:2rem;
          font-size:0.82rem;
          color:var(--color-coral-dark);
          text-align:center;
          letter-spacing:0.04em;
        ">
          ✿ &nbsp;再消費 <strong>NT$&thinsp;{{ (500 - total).toLocaleString() }}</strong> 即可享有免運費優惠！
        </div>
        <div v-else style="
          background:var(--color-forest-pale);
          border:1px solid var(--color-forest-mist);
          padding:0.9rem 1.5rem;
          margin-bottom:2rem;
          font-size:0.82rem;
          color:var(--color-forest);
          text-align:center;
          letter-spacing:0.04em;
        ">
          ✓ &nbsp;已達免運門檻，我們將為您免費配送！
        </div>

        <!-- Grid layout -->
        <div style="display:grid; grid-template-columns:1fr 340px; gap:2.5rem; align-items:start;">

          <!-- Cart items -->
          <div style="background:#fff; border:1px solid var(--color-mist);">
            <div
              v-for="item in items"
              :key="item.id"
              style="
                display:grid;
                grid-template-columns:80px 1fr auto auto;
                align-items:center;
                gap:1.5rem;
                padding:1.5rem;
                border-bottom:1px solid var(--color-mist);
              "
            >
              <img
                :src="item.product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=120'"
                :alt="item.product.name"
                style="width:80px; height:80px; object-fit:cover; border:1px solid var(--color-mist); display:block;"
              >
              <div>
                <h3 style="font-size:0.9rem; font-weight:500; color:var(--color-text-dark); margin-bottom:0.3rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:260px;">{{ item.product.name }}</h3>
                <p style="font-size:0.8rem; color:var(--color-text-light);">NT$&thinsp;{{ item.product.price.toLocaleString() }} / 束</p>
              </div>

              <!-- Qty stepper -->
              <div class="af-stepper">
                <button class="af-stepper-btn" @click="updateQuantity(item.id, item.quantity - 1)" :disabled="item.quantity <= 1">−</button>
                <span class="af-stepper-val">{{ item.quantity }}</span>
                <button class="af-stepper-btn" @click="updateQuantity(item.id, item.quantity + 1)" :disabled="item.quantity >= item.product.stock">+</button>
              </div>

              <!-- Subtotal + remove -->
              <div style="text-align:right; display:flex; flex-direction:column; align-items:flex-end; gap:0.6rem;">
                <p style="font-family:var(--font-display); font-size:1.1rem; color:var(--color-text-dark); font-weight:500; white-space:nowrap;">
                  NT$&thinsp;{{ (item.product.price * item.quantity).toLocaleString() }}
                </p>
                <button
                  @click="confirmDelete(item.id)"
                  style="font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-text-light); background:none; border:none; cursor:pointer; padding:0; transition:color 0.2s;"
                  onmouseover="this.style.color='var(--color-coral)'"
                  onmouseout="this.style.color='var(--color-text-light)'"
                >移除</button>
              </div>
            </div>

            <div style="padding:1.25rem 1.5rem; display:flex; justify-content:space-between; align-items:center; background:var(--color-ivory);">
              <a href="/" style="font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-forest-mid); text-decoration:none; transition:opacity 0.2s;"
                onmouseover="this.style.opacity='0.65'" onmouseout="this.style.opacity='1'">
                ← 繼續選購
              </a>
            </div>
          </div>

          <!-- Summary card -->
          <div style="background:#fff; border:1px solid var(--color-mist); padding:2rem; position:sticky; top:88px;">
            <h2 style="font-family:var(--font-display); font-size:1.4rem; color:var(--color-text-dark); font-weight:400; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:1px solid var(--color-mist);">訂單摘要</h2>
            <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.5rem;">
              <div style="display:flex; justify-content:space-between; font-size:0.85rem; color:var(--color-text-mid);">
                <span>商品小計</span>
                <span>NT$&thinsp;{{ total.toLocaleString() }}</span>
              </div>
              <div style="display:flex; justify-content:space-between; font-size:0.85rem; color:var(--color-text-mid);">
                <span>運費</span>
                <span :style="total >= 500 ? 'color:var(--color-forest)' : ''">{{ total >= 500 ? '免運' : 'NT$&thinsp;150' }}</span>
              </div>
            </div>
            <div style="
              border-top:1px solid var(--color-mist); padding-top:1.25rem;
              display:flex; justify-content:space-between; align-items:baseline;
              margin-bottom:1.75rem;
            ">
              <span style="font-size:0.85rem; color:var(--color-text-dark); font-weight:500;">總計</span>
              <span style="font-family:var(--font-display); font-size:1.6rem; color:var(--color-coral); line-height:1;">
                NT$&thinsp;{{ (total + (total >= 500 ? 0 : 150)).toLocaleString() }}
              </span>
            </div>
            <button @click="goCheckout" class="btn-primary" style="width:100%; text-align:center; padding:1rem;">
              前往結帳
            </button>
            <p style="font-size:0.7rem; text-align:center; color:var(--color-text-light); margin-top:0.75rem;">安全加密結帳 · 保障您的隱私</p>
          </div>
        </div>
      </template>

    </div>
  </div>

  <!-- Confirm delete dialog -->
  <div v-if="confirmVisible" class="af-overlay" @click.self="confirmVisible = false">
    <div class="af-modal scale-up" style="text-align:center;">
      <div style="font-size:2rem; margin-bottom:1rem; opacity:0.3;">✿</div>
      <h3 style="font-family:var(--font-display); font-size:1.5rem; color:var(--color-text-dark); font-weight:400; margin-bottom:0.5rem;">確認移除</h3>
      <p style="font-size:0.85rem; color:var(--color-text-light); margin-bottom:2rem; line-height:1.6;">您確定要從購物車移除這個精心挑選的花束嗎？</p>
      <div style="display:flex; gap:1rem; justify-content:center;">
        <button @click="confirmVisible = false" class="btn-outline" style="padding:0.65rem 1.5rem;">取消</button>
        <button @click="handleDelete" style="
          background:#C0392B; color:#fff; border:1.5px solid #C0392B;
          font-family:var(--font-body); font-size:0.68rem; font-weight:500;
          letter-spacing:0.16em; text-transform:uppercase;
          padding:0.65rem 1.5rem; cursor:pointer; transition:background 0.2s;
        "
          onmouseover="this.style.background='#992D22'"
          onmouseout="this.style.background='#C0392B'"
        >確認移除</button>
      </div>
    </div>
  </div>

</div>
