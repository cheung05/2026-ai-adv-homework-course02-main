<div id="app" data-product-id="<%= productId %>" class="fade-in">

  <!-- Loading -->
  <div v-if="loading" style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
    <div class="af-spinner"></div>
  </div>

  <!-- Not found -->
  <div v-else-if="notFound" style="
    min-height:60vh; display:flex; align-items:center; justify-content:center;
    text-align:center;
  ">
    <div style="padding:3rem 2rem;">
      <div style="font-size:3.5rem; margin-bottom:1.5rem; opacity:0.25; line-height:1;">✿</div>
      <h2 style="font-family:var(--font-display); font-size:1.8rem; color:var(--color-text-dark); margin-bottom:0.75rem; font-weight:400;">
        抱歉，找不到該商品
      </h2>
      <p style="font-size:0.85rem; color:var(--color-text-light); margin-bottom:2rem;">此商品可能已下架或不存在。</p>
      <a href="/" class="btn-primary">回到首頁</a>
    </div>
  </div>

  <!-- Product Detail -->
  <div v-else-if="product">
    <!-- Breadcrumb -->
    <div style="background:var(--color-ivory); border-bottom:1px solid var(--color-mist); padding:0.75rem 0;">
      <div class="af-container">
        <span class="af-crumb">
          <a href="/">首頁</a>
          <span style="margin:0 0.5rem; color:var(--color-mist);">/</span>
          <span style="color:var(--color-text-light);">{{ product.name }}</span>
        </span>
      </div>
    </div>

    <!-- Main -->
    <div style="background:var(--color-cream); padding:clamp(3rem,6vw,5rem) 0;">
      <div class="af-container">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:clamp(2.5rem,5vw,5rem); align-items:start;">

          <!-- Left: Image -->
          <div style="position:sticky; top:88px;">
            <div style="
              overflow:hidden; background:var(--color-ivory);
              border:1px solid var(--color-mist);
              position:relative;
            ">
              <img
                :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=700'"
                :alt="product.name"
                style="width:100%; aspect-ratio:1; object-fit:cover; display:block; transition:transform 0.7s ease;"
                onmouseover="this.style.transform='scale(1.04)'"
                onmouseout="this.style.transform='scale(1)'"
              >
              <!-- Stock out overlay -->
              <div v-if="product.stock <= 0" style="
                position:absolute; inset:0;
                background:rgba(247,243,238,0.75);
                display:flex; align-items:center; justify-content:center;
              ">
                <span style="font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--color-text-mid); background:#fff; padding:0.5rem 1.5rem; border:1px solid var(--color-mist);">已售完</span>
              </div>
            </div>

            <!-- Purchase notes -->
            <div style="
              background:var(--color-forest-pale);
              border:1px solid var(--color-forest-mist);
              padding:1.5rem;
              margin-top:1.5rem;
            ">
              <h3 style="font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--color-forest); margin-bottom:0.9rem; font-family:var(--font-body); font-weight:500;">✿ 購買須知</h3>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.6rem;">
                <li style="font-size:0.8rem; color:var(--color-text-mid); line-height:1.65; display:flex; gap:0.6rem;">
                  <span style="color:var(--color-forest-mid); flex-shrink:0;">·</span>
                  <span>花材均為大自然產物，實際花束可能因季節與產地略有不同。</span>
                </li>
                <li style="font-size:0.8rem; color:var(--color-text-mid); line-height:1.65; display:flex; gap:0.6rem;">
                  <span style="color:var(--color-forest-mid); flex-shrink:0;">·</span>
                  <span>大台北地區可享當日預約配送服務，請提前預訂。</span>
                </li>
                <li style="font-size:0.8rem; color:var(--color-text-mid); line-height:1.65; display:flex; gap:0.6rem;">
                  <span style="color:var(--color-forest-mid); flex-shrink:0;">·</span>
                  <span>全店消費滿 NT$500 即享免運費，未滿則收 NT$150 運費。</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Right: Info -->
          <div>
            <span style="font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--color-forest-mid); display:block; margin-bottom:1rem; font-family:var(--font-body); font-weight:500;">Exquisite Arrangement</span>

            <h1 style="font-family:var(--font-display); font-size:clamp(2rem,3.5vw,3rem); color:var(--color-text-dark); font-weight:400; margin-bottom:0.75rem; line-height:1.15;">
              {{ product.name }}
            </h1>

            <p style="font-family:var(--font-display); font-size:2rem; color:var(--color-coral); margin-bottom:1.5rem; line-height:1;">
              NT$&thinsp;{{ product.price.toLocaleString() }}
            </p>

            <!-- Stock indicator -->
            <div style="
              display:inline-flex; align-items:center; gap:0.5rem;
              padding:0.4rem 1rem;
              border:1px solid var(--color-forest-mist);
              background:var(--color-forest-pale);
              margin-bottom:1.75rem;
              font-size:0.75rem; color:var(--color-forest);
            ">
              <span style="width:7px; height:7px; border-radius:50%; background:var(--color-forest-mid); display:inline-block;"></span>
              <span v-if="product.stock > 0">庫存充足：尚有 {{ product.stock }} 件</span>
              <span v-else>目前缺貨</span>
            </div>

            <p style="font-size:0.9rem; color:var(--color-text-mid); line-height:1.85; margin-bottom:2.25rem; border-top:1px solid var(--color-mist); padding-top:1.5rem;">
              {{ product.description }}
            </p>

            <!-- Quantity -->
            <div style="display:flex; align-items:center; gap:1.5rem; margin-bottom:2rem;">
              <span style="font-size:0.72rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-text-light); font-weight:500;">數量</span>
              <div class="af-stepper">
                <button class="af-stepper-btn" @click="decrease" :disabled="quantity <= 1">−</button>
                <span class="af-stepper-val">{{ quantity }}</span>
                <button class="af-stepper-btn" @click="increase" :disabled="quantity >= product.stock">+</button>
              </div>
            </div>

            <button
              @click="addToCart"
              :disabled="adding || product.stock <= 0"
              class="btn-primary"
              style="width:100%; text-align:center; padding:1rem;"
            >
              {{ adding ? '加入中…' : product.stock <= 0 ? '已售完' : '加入購物車' }}
            </button>

            <!-- Trust badges -->
            <div style="
              display:grid; grid-template-columns:1fr 1fr 1fr;
              gap:1px; background:var(--color-mist);
              border:1px solid var(--color-mist);
              margin-top:2rem;
              overflow:hidden;
            ">
              <div style="background:var(--color-ivory); padding:1rem 0.75rem; text-align:center;">
                <p style="font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-forest-mid); margin-bottom:0.2rem; font-weight:500;">配送</p>
                <p style="font-size:0.75rem; color:var(--color-text-mid);">當日配送</p>
              </div>
              <div style="background:var(--color-ivory); padding:1rem 0.75rem; text-align:center;">
                <p style="font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-forest-mid); margin-bottom:0.2rem; font-weight:500;">包裝</p>
                <p style="font-size:0.75rem; color:var(--color-text-mid);">精品禮盒</p>
              </div>
              <div style="background:var(--color-ivory); padding:1rem 0.75rem; text-align:center;">
                <p style="font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-forest-mid); margin-bottom:0.2rem; font-weight:500;">免運</p>
                <p style="font-size:0.75rem; color:var(--color-text-mid);">滿 NT$500</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
