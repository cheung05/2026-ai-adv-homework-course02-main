<header class="af-header" id="site-header">
  <div class="af-container" style="display:flex; align-items:center; justify-content:space-between; height:72px;">

    <!-- Logo -->
    <a href="/" class="af-logo">
      Aura Flora
      <span class="af-logo-sub">花漾生活</span>
    </a>

    <!-- Nav -->
    <nav style="display:flex; align-items:center; gap:2.5rem;">
      <a href="/" class="af-nav-link">商品列表</a>
      <a href="/cart" class="af-nav-link" style="position:relative;">
        購物車
        <span
          id="cart-badge"
          style="display:none; position:absolute; top:-8px; right:-14px;
                 background:var(--color-coral); color:#fff;
                 font-size:9px; font-weight:600;
                 width:16px; height:16px;
                 border-radius:50%;
                 display:none; align-items:center; justify-content:center;"
        ></span>
      </a>
      <a id="orders-link" href="/orders" class="af-nav-link" style="display:none;">我的訂單</a>
    </nav>

    <!-- Auth -->
    <div id="auth-nav">
      <a href="/login" class="btn-primary" style="padding:0.6rem 1.5rem; font-size:0.65rem;">登入</a>
    </div>
  </div>
</header>

<script>
  // Add scroll shadow
  window.addEventListener('scroll', () => {
    document.getElementById('site-header')?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>
